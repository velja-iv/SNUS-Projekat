{
  "ConnectionStrings": {
    "SensorSystem": "Host=localhost;Port=5432;Database=sensorsystem;Username=postgres;Password=postgres"
  },
  "SensorSystem": {
    "RequiredActiveSensors": 5,
    "InactiveTimeoutSeconds": 10,
    "DoSMaxMessagesPerSecond": 10,
    "DoSBlockSeconds": 30,
    "DeniedRegisterRetrySeconds": 60,
    "ReplayToleranceSeconds": 30
  },
  "Consensus": {
    "WindowSeconds": 60,
    "TrimPercent": 20,
    "OutlierThresholdCelsius": 15.0,
    "BadSensorIncidentThreshold": 3
  },
  "AlarmThresholds": {
    "Priority1Low": 50.0,
    "Priority1High": 90.0,
    "Priority2Low": 40.0,
    "Priority2High": 100.0,
    "Priority3Low": 30.0,
    "Priority3High": 110.0
  },
  "Services": {
    "IngestionBaseUrl": "http://localhost:8080"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
