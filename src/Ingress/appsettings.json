{
  "ReverseProxy": {
    "Routes": {
      "ingest-route": {
        "ClusterId": "ingestion-cluster",
        "Match": {
          "Path": "/api/ingest/{**catch-all}"
        }
      },
      "reports-route": {
        "ClusterId": "reports-cluster",
        "Match": {
          "Path": "/api/reports/{**catch-all}"
        }
      },
      "notifications-route": {
        "ClusterId": "notification-cluster",
        "Match": {
          "Path": "/api/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "ingestion-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8081/"
          }
        }
      },
      "reports-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8083/"
          }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8082/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
